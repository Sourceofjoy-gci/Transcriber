# Transcriber local deployment settings.
# Copy this file to .env, then replace every replace-with-* value before use.
#
# Generate application and credential keys with:
#   python scripts/generate-encryption-key.py
#
# Generate the bootstrap password with your password manager. Do not commit .env.

APP_ENV=development
APP_SECRET_KEY=replace-with-generated-32-byte-or-longer-secret
CREDENTIAL_ENCRYPTION_KEY=replace-with-generated-32-byte-url-safe-key
CREDENTIAL_KEY_VERSION=1

BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-bootstrap-password
BOOTSTRAP_ORGANISATION_NAME=Local Organisation

DATABASE_URL=postgresql+psycopg://transcriber:transcriber@postgres:5432/transcriber
REDIS_URL=redis://redis:6379/0
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:8088

STORAGE_PROVIDER=local_filesystem
STORAGE_ROOT=/var/lib/transcriber/storage
MODEL_ROOT=/var/lib/transcriber/models

S3_BUCKET=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_USE_SSL=true

FFPROBE_PATH=ffprobe
FFMPEG_PATH=ffmpeg
MAX_UPLOAD_BYTES=2147483648

MALWARE_SCANNER_MODE=placeholder
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=10

DEFAULT_TRANSCRIPTION_PROVIDER=faster_whisper
DEFAULT_TRANSCRIPTION_MODEL=base
TRANSCRIPTION_DEVICE=auto
TRANSCRIPTION_COMPUTE_TYPE=int8

EXTERNAL_APIS_ALLOWED=false
LOCAL_ONLY_ENFORCED=true
POST_PROCESSING_PROVIDER=stub
MULTIMODAL_PROVIDER=stub
DEFAULT_REPORT_TEMPLATE_KIND=presentation

LOG_FORMAT=json
RATE_LIMIT_STORAGE=redis
RATE_LIMIT_NAMESPACE=transcriber:rate-limit
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_UPLOAD=30/minute
RATE_LIMIT_EXPORT=30/minute
RATE_LIMIT_PROVIDER_TEST=20/minute
RATE_LIMIT_AI_RUN=20/minute
WORKER_HEALTH_TIMEOUT_SECONDS=0.5

CELERY_CPU_CONCURRENCY=2
CELERY_GPU_CONCURRENCY=1
